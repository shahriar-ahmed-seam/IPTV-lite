<?xml version="1.0" encoding="utf-8"?>
<!-- Grid tile background. Glowing violet gradient + bright border on D-pad focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/accent"
                android:endColor="@color/accent_deep"
                android:angle="135" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/text_focused" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/item_selected" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/tile_idle2"
                android:endColor="@color/tile_idle"
                android:angle="135" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/tile_stroke" />
        </shape>
    </item>
</selector>
