<?xml version="1.0" encoding="utf-8"?>
<!-- Grid tile background. Strong red border + fill on D-pad focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/item_focused" />
            <corners android:radius="8dp" />
            <stroke android:width="3dp" android:color="@color/text_focused" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tile_idle" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/tile_stroke" />
        </shape>
    </item>
</selector>
