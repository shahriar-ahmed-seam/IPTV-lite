<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/screen_bg"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="12dp">

    <!-- Header row: brand (left) + search + source dropdown (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brand_title"
            android:fontFamily="@font/bangla"
            android:textColor="@color/accent"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:shadowColor="@color/accent"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="16"
            android:paddingEnd="20dp" />

        <!-- Search field (scoped to the active source) -->
        <EditText
            android:id="@+id/searchBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxWidth="420dp"
            android:background="@drawable/search_bg"
            android:hint="Search channels..."
            android:textColorHint="@color/header_text"
            android:textColor="@color/text_focused"
            android:textSize="15sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Source"
            android:textColor="@color/header_text"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp" />

        <Spinner
            android:id="@+id/sourceSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="140dp"
            android:background="@drawable/chip_bg"
            android:focusable="true"
            android:popupBackground="@color/list_bg" />

        <!-- Add / manage custom sources -->
        <ImageView
            android:id="@+id/addSourceButton"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:padding="10dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@drawable/chip_bg"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Add source" />

        <!-- Favourites toggle button (star). Shows the saved-favourites view. -->
        <ImageView
            android:id="@+id/favButton"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:padding="9dp"
            android:src="@drawable/ic_star_gold"
            android:background="@drawable/chip_bg"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Favourites" />
    </LinearLayout>

    <!-- Category bar (horizontal, scrollable via D-pad) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:focusable="true"
        android:descendantFocusability="afterDescendants" />

    <!-- Channel grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:focusable="true"
        android:descendantFocusability="afterDescendants" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/text_focused"
        android:textSize="18sp"
        android:text="Loading channels..." />
</LinearLayout>
